{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "outDir": "out",
    "lib": [
      "es2020",
      "dom"
    ],
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "composite": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "pretty": true,
    "stripInternal": true,
    "noImplicitOverride": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src",
    "third_party"
  ],
  "ts-node": {
    "compilerOptions": {
      "types": [
        "node",
        "jasmine"
      ]
    }
  }
}
