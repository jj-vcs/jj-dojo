{
  "name": "jj-dojo",
  "displayName": "Jujutsu Dojo",
  "publisher": "google",
  "description": "VSCode extension to add support for interacting with Jujutsu (jj) repositories.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.117.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.jj"
  ],
  "main": "./bazel-bin/out/src/extension.js",
  "contributes": {
    "views": {},
    "commands": [],
    "configuration": {},
    "menus": {}
  },
  "scripts": {
    "compile": "bazel build //:extension",
    "lint": "gts lint",
    "clean": "gts clean",
    "fix": "gts fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "25.x",
    "@types/vscode": "^1.118.0",
    "gts": "^7.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
