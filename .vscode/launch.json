{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extension",
        "vscode.git",
      ],
      "outFiles": [
        "${workspaceFolder}/bazel-bin/out/**/*.js"
      ],
      "preLaunchTask": "Compile extension"
    }
  ]
}
